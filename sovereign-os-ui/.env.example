# ─────────────────────────────────────────────────────────────
# sovereign-os-ui — Environment Variables (Vite)
# ENV-01: Bu dosyayı .env olarak kopyala ve değerleri doldur.
# Not: VITE_ ön ekli değişkenler build'e gömülür — GİZLİ DEĞER KOYMA.
# ─────────────────────────────────────────────────────────────

# ── Backend bağlantısı (ZORUNLU) ────────────────────────────────
# sovereign-engine'in Railway/production URL'i
VITE_ENGINE_URL=

# ── Supabase (ZORUNLU) ───────────────────────────────────────────
# Anon key public'tir, sorun değil — RLS ile korunur.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Admin Paneli (ZORUNLU — SEC-02) ──────────────────────────────
# Tanımsızsa /admin/waitlist route'u tamamen kapalı (404 davranışı).
# Backend'deki ADMIN_PASSWORD ile AYNI değeri kullan.
VITE_ADMIN_PASSWORD=
